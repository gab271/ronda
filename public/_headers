# Cloudflare Pages response headers.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()

# Vite emits content-hashed filenames for everything under /assets, so these are
# safe to cache permanently. This matters more than usual here: a player who
# opens two tournament links in a weekend should download the bundle once.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# The HTML shell must not be cached, or a deploy never reaches returning users.
/index.html
  Cache-Control: public, max-age=0, must-revalidate
