# ⚠️  THIS FILE IS COMMITTED TO GIT. Placeholders only.
#     Real values go in .env.local, which is gitignored.
#
# Copy to .env.local and fill in from your Supabase project:
#   Project Settings → Data API
#
# IMPORTANT: the VITE_ prefix means "bundled into the client and public forever".
# Only ever put publishable values here.
#
# The anon key IS meant to be public — it identifies the project and authorises
# nothing. All access control lives in RLS policies (supabase/migrations/).
# Do not try to hide it; doing so would break the public tournament page, which
# must work with no account at all.
#
# NEVER put here: the service_role key, the Postgres connection string, SMTP
# credentials, or any payment secret. Those bypass RLS entirely.
# `npm run build` fails if any of them reach dist/.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
